<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Edit product</title>
</head>
<body>
    <h1>Edit Product</h1>
    <form action="/farmStand/product/<%=product._id%>?_method=PUT" method="POST">
        <label for="name">Product Name</label>
        <input type="text" id= "name" name="name" placeholder="product name" value="<%=product.name%>">
        <label for="number">Price (Unit)</label>
        <input type="number" id= "price" name="price" placeholder="price" value="<%=product.price%>">
        <label for="category">Select Category</label>
        <select name="category" id="category">
            <%for(let category of categories){%>
                <option value="<%=category%>" <%= product.category === category ? 'selected' : '' %>><%=category%></option>
            <%}%>
        </select>
        <button>Submit</button>
    </form>
</body>
</html>